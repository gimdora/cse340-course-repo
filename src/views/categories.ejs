<%- include('partials/header') %>

  <main>
    <h1>
      <%= title %>
    </h1>

    <h2>Categories</h2>
    <p>Browse the service categories from the database.</p>

    <% if (isAdmin) { %>
      <p><a href="/new-category">Add a New Category</a></p>
      <% } %>

        <% if (categories.length===0) { %>
          <p>No categories are available yet.</p>
          <% } else { %>
            <% categories.forEach(category=> { %>
              <p>
                <a href="/category/<%= category.category_id %>">
                  <%= category.name %>
                </a>
              </p>
              <% }) %>
                <% } %>
  </main>

  <%- include('partials/footer') %>