<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="/css/main.css" />
</head>

<body>
  <header class="site-header">
    <nav class="nav">
      <a class="nav-link <%= path === '/' ? 'active' : '' %>" href="/">Home</a>

      <a class="nav-link <%= path === '/organizations' || path.startsWith('/organization/') || path === '/new-organization' || path.startsWith('/edit-organization/') ? 'active' : '' %>"
        href="/organizations">
        Organizations
      </a>

      <a class="nav-link <%= path === '/projects' || path.startsWith('/project/') || path === '/new-project' || path.startsWith('/edit-project/') || path.startsWith('/assign-categories/') ? 'active' : '' %>"
        href="/projects">
        Projects
      </a>

      <a class="nav-link <%= path === '/categories' || path.startsWith('/category/') || path === '/new-category' || path.startsWith('/edit-category/') ? 'active' : '' %>"
        href="/categories">
        Categories
      </a>

      <% if (isLoggedIn) { %>
        <a class="nav-link <%= path === '/dashboard' ? 'active' : '' %>" href="/dashboard">Dashboard</a>

        <% if (isAdmin) { %>
          <a class="nav-link <%= path === '/users' ? 'active' : '' %>" href="/users">Users</a>
          <% } %>

            <a class="nav-link" href="/logout">Logout</a>
            <% } else { %>
              <a class="nav-link <%= path === '/register' ? 'active' : '' %>" href="/register">Register</a>
              <a class="nav-link <%= path === '/login' ? 'active' : '' %>" href="/login">Login</a>
              <% } %>
    </nav>
  </header>

  <% const messages=flash(); %>
    <% const hasMessages=Object.keys(messages).some(type=> messages[type].length > 0); %>

      <% if (hasMessages) { %>
        <div class="flash-wrap">
          <% Object.keys(messages).forEach(type=> { %>
            <% messages[type].forEach(msg=> { %>
              <div class="alert alert-<%= type %>">
                <%= msg %>
              </div>
              <% }) %>
                <% }) %>
        </div>
        <% } %>