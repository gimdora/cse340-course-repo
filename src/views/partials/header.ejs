<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="/css/main.css" />
</head>

<body>
  <header class="site-header">
    <nav class="nav">
      <a class="nav-link <%= path === '/' ? 'active' : '' %>" href="/">Home</a>
      <a class="nav-link <%= path === '/organizations' || path.startsWith('/organization/') ? 'active' : '' %>"
        href="/organizations">Organizations</a>
      <a class="nav-link <%= path === '/projects' || path.startsWith('/project/') ? 'active' : '' %>"
        href="/projects">Projects</a>
      <a class="nav-link <%= path === '/categories' || path.startsWith('/category/') ? 'active' : '' %>"
        href="/categories">Categories</a>
    </nav>
  </header>

  <% const messages=flash(); %>
    <% const hasMessages=Object.keys(messages).some(type=> messages[type].length > 0); %>

      <% if (hasMessages) { %>
        <div class="flash-wrap">
          <% Object.keys(messages).forEach(type=> { %>
            <% messages[type].forEach(msg=> { %>
              <div class="alert alert-<%= type %>">
                <%= msg %>
              </div>
              <% }) %>
                <% }) %>
        </div>
        <% } %>