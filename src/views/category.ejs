<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>
            <%= categoryDetails.name %>
        </h2>

        <h3>Service Projects</h3>

        <% if (projects.length===0) { %>
            <p>No service projects are assigned to this category yet.</p>
            <% } else { %>
                <ul>
                    <% projects.forEach(project=> { %>
                        <li>
                            <a href="/project/<%= project.project_id %>">
                                <%= project.name %>
                            </a>
                            -
                            <a href="/organization/<%= project.organization_id %>">
                                <%= project.organization_name %>
                            </a>
                            <p>
                                <%= project.description %>
                            </p>
                        </li>
                        <% }) %>
                </ul>
                <% } %>
    </main>

    <%- include('partials/footer') %>