<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>
            <%= categoryDetails.name %>
        </h2>

        <% if (isAdmin) { %>
            <p>
                <a href="/edit-category/<%= categoryDetails.category_id %>">Edit Category</a>
            </p>
            <% } %>

                <h3>Service Projects</h3>

                <% if (projects.length===0) { %>
                    <p>No service projects are assigned to this category yet.</p>
                    <% } else { %>
                        <% projects.forEach(project=> { %>
                            <div>
                                <h4>
                                    <a href="/project/<%= project.project_id %>">
                                        <%= project.name %>
                                    </a>
                                </h4>
                                <p>
                                    <strong>Organization:</strong>
                                    <a href="/organization/<%= project.organization_id %>">
                                        <%= project.organization_name %>
                                    </a>
                                </p>
                                <p>
                                    <%= project.description %>
                                </p>
                            </div>
                            <% }) %>
                                <% } %>
    </main>

    <%- include('partials/footer') %>