<%- include('partials/header') %>

  <main>
    <h1>
      <%= title %>
    </h1>

    <h2>Welcome to the CSE 340 Service Network!</h2>
    <p>Here are a few of our partner organizations:</p>

    <ul class="org-list">
      <% organizations.forEach(organization=> { %>
        <li class="org-item">
          <img class="org-logo" src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">

          <strong>
            <a href="/organization/<%= organization.organization_id %>">
              <%= organization.name %>
            </a>
          </strong>

          : <%= organization.contact_email %>
            <p>
              <%= organization.description %>
            </p>
        </li>
        <% }) %>
    </ul>
  </main>

  <%- include('partials/footer') %>