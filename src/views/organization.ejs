<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>
            <%= organizationDetails.name %>
        </h2>
        <p><strong>Email:</strong>
            <%= organizationDetails.contact_email %>
        </p>
        <p><strong>Description:</strong>
            <%= organizationDetails.description %>
        </p>

        <% if (isAdmin) { %>
            <p>
                <a href="/edit-organization/<%= organizationDetails.organization_id %>">Edit Organization</a>
            </p>
            <% } %>

                <h3>Service Projects</h3>

                <% if (projects.length===0) { %>
                    <p>No service projects are available for this organization yet.</p>
                    <% } else { %>
                        <% projects.forEach(project=> { %>
                            <div>
                                <h4>
                                    <a href="/project/<%= project.project_id %>">
                                        <%= project.name %>
                                    </a>
                                </h4>
                                <p>
                                    <%= project.description %>
                                </p>
                            </div>
                            <% }) %>
                                <% } %>
    </main>

    <%- include('partials/footer') %>